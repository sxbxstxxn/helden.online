# Django
SECRET_KEY=dev-only-helden-online-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Temporärer Seitenschutz, lokal standardmäßig aus.
SITE_PASSWORD_ENABLED=False
SITE_PASSWORD_USERNAME=
SITE_PASSWORD=

# Production security toggles
# Enable these only when the site is served via HTTPS.
SECURE_PROXY_SSL_HEADER=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_CONTENT_TYPE_NOSNIFF=True
CSRF_TRUSTED_ORIGINS=

# Lokale Entwicklung mit PostgreSQL
DATABASE_URL=postgres://postgres:postgres@db:5432/helden_online
POSTGRES_DB=helden_online
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# E-Mail lokal nur in der Konsole ausgeben
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_USE_TLS=False
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=dev@localhost
CONTACT_EMAIL=mail@helden.online

# RSS-News auf der Startseite
RSS_FEED_CACHE_SECONDS=1800
RSS_FEED_ITEMS_PER_SOURCE=8
RSS_FEED_MAX_ITEMS=24
